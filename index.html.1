      type: "POST",
      async: false,
      }).done(function(data) {
          if (data[0] == 'OK'){
              $('#loginMessage').remove();

          } else {
              document.getElementById("btnLogin").disabled = "true";
              htmlString = "<div id='loginMessage' class='tabContents'><div class='pageMsg caution'><p>";
