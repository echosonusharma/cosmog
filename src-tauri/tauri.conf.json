{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cosmog",
  "version": "0.1.8",
  "identifier": "com.sonus.cosmog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "cosmog",
        "width": 1200,
        "height": 740,
        "minWidth": 820,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Sonu Sharma",
    "copyright": "Copyright © 2026 Sonu Sharma",
    "shortDescription": "S3-compatible object storage manager",
    "longDescription": "Cosmog is a desktop app for managing files across S3-compatible storage providers including AWS S3, Cloudflare R2, Backblaze B2, DigitalOcean Spaces, Wasabi, and MinIO.",
    "homepage": "https://github.com/sonusharma/cosmog",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsi"
      }
    }
  }
}
